# SoundWave Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/soundwave

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=soundwave_super_secret_key_change_in_production_2024

# Admin Secret (used when creating admin accounts)
ADMIN_SECRET=soundwave_admin_secret_2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
